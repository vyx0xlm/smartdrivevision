# Flask
SECRET_KEY=change-me-to-a-long-random-string

# Public site URL (for password reset links in emails)
# APP_URL=https://smartdrive-vision.onrender.com

# Render PostgreSQL (persistent data on free tier — expires after 30 days)
# DATABASE_URL=postgresql://user:pass@host/dbname

# Render persistent disk (paid alternative — SQLite file on /var/data)
# DATABASE_PATH=/var/data/smartdrive.db
# DATA_DIR=/var/data

# Live / proxy (Render sets RENDER=true automatically)
# BEHIND_PROXY=1
# PORT=5000
# FLASK_DEBUG=0

# Password reset email — pick ONE option below:

# Option A (recommended on Render — uses HTTPS, not blocked):
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=SmartDrive <onboarding@resend.dev>
# For production, verify your domain at resend.com and use e.g. noreply@yourdomain.com

# Option B (local dev with Gmail — use an App Password, not your normal password):
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=1
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your-gmail-app-password
# MAIL_DEFAULT_SENDER=SmartDrive <your@gmail.com>

# Google sign-in — local files:
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_WEB_CONFIG_PATH=./firebase_web_config.json

# Google sign-in — Render / cloud (paste full JSON as one line in dashboard):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_WEB_CONFIG={"apiKey":"...","authDomain":"...","projectId":"..."}
